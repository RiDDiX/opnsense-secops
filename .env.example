# OPNsense connection
OPNSENSE_HOST=192.168.1.1
OPNSENSE_API_KEY=your_api_key_here
OPNSENSE_API_SECRET=your_api_secret_here

# Set to 1 only if your firewall uses a self signed cert.
OPNSENSE_INSECURE_TLS=0

# Per request timeout in seconds.
OPNSENSE_API_TIMEOUT=30

# Optional. When set, secrets in /app/config/opnsense.json are stored encrypted.
# Pass either a Fernet key (44 chars, base64, ends with '=') or a passphrase.
SECOPS_SECRET_KEY=

# Scanning
SCAN_NETWORK=192.168.1.0/24
ADDITIONAL_NETWORKS=
